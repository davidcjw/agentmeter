{
  "name": "agentmeter",
  "version": "0.3.0",
  "description": "See what your AI coding agent actually costs — and where it wastes tokens. Parses local Claude Code transcripts into a cost report (by project, day, tool, model, skill/plugin/MCP, main-loop vs subagent) plus an efficiency report (errors, duplicate calls, re-read files, denied permissions).",
  "type": "module",
  "bin": {
    "agentmeter": "bin/agentmeter.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node bin/agentmeter.js"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "claude-code",
    "tokens",
    "cost",
    "usage",
    "observability",
    "analytics",
    "cli",
    "developer-tools"
  ],
  "author": "David Chong",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidcjw/agentmeter.git"
  },
  "bugs": {
    "url": "https://github.com/davidcjw/agentmeter/issues"
  },
  "homepage": "https://github.com/davidcjw/agentmeter#readme",
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
